<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#080808"
    android:paddingTop="48dp">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingHorizontal="20dp"
        android:paddingBottom="16dp">

        <TextView
            android:id="@+id/tvTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerVertical="true"
            android:text="GLYPH DRAW"
            android:textColor="#FFFFFF"
            android:textSize="13sp"
            android:letterSpacing="0.3"
            android:fontFamily="monospace" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:orientation="horizontal"
            android:background="@drawable/tab_bg"
            android:padding="3dp">

            <TextView
                android:id="@+id/btnModeGrid"
                android:layout_width="52dp"
                android:layout_height="28dp"
                android:text="GRID"
                android:textColor="#FFFFFF"
                android:textSize="10sp"
                android:letterSpacing="0.1"
                android:fontFamily="monospace"
                android:gravity="center"
                android:background="@drawable/tab_selected" />

            <TextView
                android:id="@+id/btnModeFreehand"
                android:layout_width="52dp"
                android:layout_height="28dp"
                android:text="FREE"
                android:textColor="#666666"
                android:textSize="10sp"
                android:letterSpacing="0.1"
                android:fontFamily="monospace"
                android:gravity="center"
                android:background="@android:color/transparent" />
        </LinearLayout>
    </RelativeLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingHorizontal="20dp"
        android:paddingBottom="12dp"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/btnGallery"
            android:layout_width="wrap_content"
            android:layout_height="28dp"
            android:text="GALERİ"
            android:textColor="#888888"
            android:textSize="9sp"
            android:letterSpacing="0.15"
            android:fontFamily="monospace"
            android:gravity="center"
            android:paddingHorizontal="12dp"
            android:background="@drawable/pill_outline"
            android:layout_marginEnd="8dp" />

        <TextView
            android:id="@+id/btnAnimation"
            android:layout_width="wrap_content"
            android:layout_height="28dp"
            android:text="ANİMASYON"
            android:textColor="#888888"
            android:textSize="9sp"
            android:letterSpacing="0.15"
            android:fontFamily="monospace"
            android:gravity="center"
            android:paddingHorizontal="12dp"
            android:background="@drawable/pill_outline"
            android:layout_marginEnd="8dp" />

        <TextView
            android:id="@+id/btnImport"
            android:layout_width="wrap_content"
            android:layout_height="28dp"
            android:text="IMPORT"
            android:textColor="#888888"
            android:textSize="9sp"
            android:letterSpacing="0.15"
            android:fontFamily="monospace"
            android:gravity="center"
            android:paddingHorizontal="12dp"
            android:background="@drawable/pill_outline" />
    </LinearLayout>

    <!-- Kare çizim alanı: padding ile margin'den tam kare -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingHorizontal="20dp">

        <FrameLayout
            android:id="@+id/drawingContainer"
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <com.kaelvalen.glyphmatrixdraw.ui.PixelGridView
                android:id="@+id/pixelGridView"
                android:layout_width="match_parent"
                android:layout_height="match_parent" />

            <com.kaelvalen.glyphmatrixdraw.ui.FreehandCanvasView
                android:id="@+id/freehandCanvasView"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:visibility="gone" />
        </FrameLayout>
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:paddingHorizontal="20dp"
        android:paddingTop="16dp"
        android:paddingBottom="24dp"
        android:gravity="bottom">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingBottom="12dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="PARLAKLIK"
                android:textColor="#444444"
                android:textSize="9sp"
                android:letterSpacing="0.2"
                android:fontFamily="monospace"
                android:layout_marginEnd="12dp"
                android:minWidth="72dp" />

            <SeekBar
                android:id="@+id/seekBrightness"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:progressTint="#FFFFFF"
                android:thumbTint="#FFFFFF" />

            <TextView
                android:id="@+id/tvBrightness"
                android:layout_width="40dp"
                android:layout_height="wrap_content"
                android:text="100%"
                android:textColor="#666666"
                android:textSize="10sp"
                android:fontFamily="monospace"
                android:gravity="end"
                android:layout_marginStart="12dp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/gridControls"
            android:layout_width="match_parent"
            android:layout_height="36dp"
            android:orientation="horizontal"
            android:paddingBottom="10dp">

            <TextView
                android:id="@+id/btnErase"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:text="SİL"
                android:textColor="#555555"
                android:textSize="9sp"
                android:letterSpacing="0.2"
                android:fontFamily="monospace"
                android:gravity="center" />

            <View android:layout_width="1dp" android:layout_height="16dp"
                android:layout_gravity="center_vertical" android:background="#222222" />

            <TextView
                android:id="@+id/btnInvert"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:text="İNVERT"
                android:textColor="#555555"
                android:textSize="9sp"
                android:letterSpacing="0.2"
                android:fontFamily="monospace"
                android:gravity="center" />

            <View android:layout_width="1dp" android:layout_height="16dp"
                android:layout_gravity="center_vertical" android:background="#222222" />

            <TextView
                android:id="@+id/btnClear"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:text="TEMİZLE"
                android:textColor="#555555"
                android:textSize="9sp"
                android:letterSpacing="0.2"
                android:fontFamily="monospace"
                android:gravity="center" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/freehandControls"
            android:layout_width="match_parent"
            android:layout_height="36dp"
            android:orientation="horizontal"
            android:visibility="gone"
            android:paddingBottom="10dp">

            <TextView
                android:id="@+id/btnApplyFreehand"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:text="GRİD'E AKTAR"
                android:textColor="#AAAAAA"
                android:textSize="9sp"
                android:letterSpacing="0.2"
                android:fontFamily="monospace"
                android:gravity="center" />

            <View android:layout_width="1dp" android:layout_height="16dp"
                android:layout_gravity="center_vertical" android:background="#222222" />

            <TextView
                android:id="@+id/btnClearFreehand"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:text="TEMİZLE"
                android:textColor="#555555"
                android:textSize="9sp"
                android:letterSpacing="0.2"
                android:fontFamily="monospace"
                android:gravity="center" />
        </LinearLayout>

        <TextView
            android:id="@+id/btnSend"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="GLYPH'E GÖNDER"
            android:textColor="#080808"
            android:textSize="11sp"
            android:letterSpacing="0.25"
            android:fontFamily="monospace"
            android:gravity="center"
            android:background="@drawable/btn_primary" />
    </LinearLayout>

</LinearLayout>

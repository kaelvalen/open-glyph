<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:paddingHorizontal="18dp"
    android:paddingVertical="10dp"
    android:gravity="center_vertical"
    android:background="?android:attr/selectableItemBackground">

    <ImageView
        android:id="@+id/imgAnimationThumb"
        android:layout_width="56dp"
        android:layout_height="56dp"
        android:scaleType="fitXY"
        android:background="#111111"
        android:contentDescription="@string/animation_thumb_desc" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical"
        android:layout_marginHorizontal="14dp">

        <TextView
            android:id="@+id/tvAnimationName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#EEEEEE"
            android:textSize="12sp"
            android:fontFamily="monospace" />

        <TextView
            android:id="@+id/tvAnimationFrames"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#666666"
            android:textSize="9sp"
            android:fontFamily="monospace"
            android:layout_marginTop="2dp" />

        <TextView
            android:id="@+id/tvAnimationDelay"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#666666"
            android:textSize="9sp"
            android:fontFamily="monospace" />
    </LinearLayout>

    <TextView
        android:id="@+id/btnAnimFavorite"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:text="@string/favorite_off"
        android:textColor="#666666"
        android:textSize="20sp"
        android:gravity="center" />

    <TextView
        android:id="@+id/btnAnimMore"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:text="⋯"
        android:textColor="#AAAAAA"
        android:textSize="18sp"
        android:fontFamily="monospace"
        android:gravity="center" />
</LinearLayout>

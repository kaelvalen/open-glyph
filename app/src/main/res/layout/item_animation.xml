<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:paddingHorizontal="20dp"
    android:paddingVertical="12dp"
    android:gravity="center_vertical">

    <ImageView
        android:id="@+id/imgAnimationThumb"
        android:layout_width="56dp"
        android:layout_height="56dp"
        android:scaleType="fitXY"
        android:background="#111111"
        android:contentDescription="@string/animation_thumb_desc" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical"
        android:layout_marginHorizontal="16dp">

        <TextView
            android:id="@+id/tvAnimationName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#CCCCCC"
            android:textSize="12sp"
            android:fontFamily="monospace" />

        <TextView
            android:id="@+id/tvAnimationFrames"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#666666"
            android:textSize="10sp"
            android:fontFamily="monospace"
            android:layout_marginTop="4dp" />

        <TextView
            android:id="@+id/tvAnimationDelay"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#666666"
            android:textSize="10sp"
            android:fontFamily="monospace" />

    </LinearLayout>

    <TextView
        android:id="@+id/btnLoadAnimation"
        android:layout_width="wrap_content"
        android:layout_height="32dp"
        android:text="@string/load"
        android:textColor="#FFFFFF"
        android:textSize="9sp"
        android:letterSpacing="0.2"
        android:fontFamily="monospace"
        android:gravity="center"
        android:paddingHorizontal="12dp"
        android:background="@drawable/btn_outline_sm"
        android:layout_marginEnd="8dp" />

    <TextView
        android:id="@+id/btnDeleteAnimation"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:text="@string/close"
        android:textColor="#444444"
        android:textSize="14sp"
        android:gravity="center" />
</LinearLayout>

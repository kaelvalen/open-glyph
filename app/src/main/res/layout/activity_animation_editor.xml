<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0D0D0D"
    android:padding="12dp">

    <!-- Header -->
    <TextView
        android:id="@+id/tvAnimTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="ANIMATION"
        android:textColor="#FFFFFF"
        android:textSize="16sp"
        android:letterSpacing="0.2"
        android:fontFamily="monospace"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <Button
        android:id="@+id/btnAnimBack"
        style="@style/Widget.AppCompat.Button.Borderless"
        android:layout_width="wrap_content"
        android:layout_height="32dp"
        android:text="← BACK"
        android:textColor="#888888"
        android:textSize="10sp"
        android:fontFamily="monospace"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Animation name -->
    <EditText
        android:id="@+id/etAnimName"
        android:layout_width="0dp"
        android:layout_height="36dp"
        android:layout_marginTop="8dp"
        android:hint="Animation name"
        android:textColor="#FFFFFF"
        android:textColorHint="#444444"
        android:textSize="12sp"
        android:fontFamily="monospace"
        android:background="#1A1A1A"
        android:paddingHorizontal="8dp"
        android:inputType="text"
        android:imeOptions="actionDone"
        app:layout_constraintTop_toBottomOf="@id/tvAnimTitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Frame strip -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvFrames"
        android:layout_width="0dp"
        android:layout_height="72dp"
        android:layout_marginTop="8dp"
        android:orientation="horizontal"
        app:layout_constraintTop_toBottomOf="@id/etAnimName"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Pixel grid editor -->
    <FrameLayout
        android:id="@+id/animDrawingContainer"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="8dp"
        app:layout_constraintTop_toBottomOf="@id/rvFrames"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toTopOf="@id/delayRow"
        app:layout_constraintDimensionRatio="1:1">

        <com.kaelvalen.glyphmatrixdraw.ui.PixelGridView
            android:id="@+id/animPixelGrid"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />

    </FrameLayout>

    <!-- Delay row -->
    <LinearLayout
        android:id="@+id/delayRow"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginTop="8dp"
        app:layout_constraintTop_toBottomOf="@id/animDrawingContainer"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="DELAY"
            android:textColor="#888888"
            android:textSize="10sp"
            android:fontFamily="monospace"
            android:layout_marginEnd="8dp" />

        <SeekBar
            android:id="@+id/seekDelay"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:max="195"
            android:progress="9"
            android:progressTint="#FFFFFF"
            android:thumbTint="#FFFFFF" />

        <TextView
            android:id="@+id/tvDelayMs"
            android:layout_width="60dp"
            android:layout_height="wrap_content"
            android:text="250ms"
            android:textColor="#888888"
            android:textSize="11sp"
            android:fontFamily="monospace"
            android:gravity="end"
            android:layout_marginStart="8dp" />

    </LinearLayout>

    <!-- Controls row -->
    <LinearLayout
        android:id="@+id/animControls"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="8dp"
        app:layout_constraintTop_toBottomOf="@id/delayRow"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <Button
            android:id="@+id/btnAddFrame"
            style="@style/Widget.AppCompat.Button.Borderless"
            android:layout_width="0dp"
            android:layout_height="36dp"
            android:layout_weight="1"
            android:text="+ FRAME"
            android:textColor="#CCCCCC"
            android:textSize="10sp"
            android:fontFamily="monospace" />

        <Button
            android:id="@+id/btnDupFrame"
            style="@style/Widget.AppCompat.Button.Borderless"
            android:layout_width="0dp"
            android:layout_height="36dp"
            android:layout_weight="1"
            android:text="⧉ DUPLICATE"
            android:textColor="#CCCCCC"
            android:textSize="10sp"
            android:fontFamily="monospace" />

        <Button
            android:id="@+id/btnDeleteFrame"
            style="@style/Widget.AppCompat.Button.Borderless"
            android:layout_width="0dp"
            android:layout_height="36dp"
            android:layout_weight="1"
            android:text="✕ FRAME"
            android:textColor="#666666"
            android:textSize="10sp"
            android:fontFamily="monospace" />

        <Button
            android:id="@+id/btnPlayAnim"
            style="@style/Widget.AppCompat.Button.Borderless"
            android:layout_width="0dp"
            android:layout_height="36dp"
            android:layout_weight="1"
            android:text="▶ PLAY"
            android:textColor="#CCCCCC"
            android:textSize="10sp"
            android:fontFamily="monospace" />

    </LinearLayout>

    <!-- Send button -->
    <Button
        android:id="@+id/btnSendAnim"
        android:layout_width="0dp"
        android:layout_height="48dp"
        android:layout_marginTop="8dp"
        android:text="SEND TO GLYPH"
        android:textColor="#000000"
        android:textSize="12sp"
        android:fontFamily="monospace"
        android:letterSpacing="0.1"
        android:backgroundTint="#FFFFFF"
        app:layout_constraintTop_toBottomOf="@id/animControls"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toBottomOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>

<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#080808"
    android:paddingTop="40dp">

    <!-- Header -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingHorizontal="18dp"
        android:paddingBottom="10dp">

        <TextView
            android:id="@+id/tvFxTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerVertical="true"
            android:text="@string/effects_title"
            android:textColor="#FFFFFF"
            android:textSize="13sp"
            android:letterSpacing="0.3"
            android:fontFamily="monospace" />

        <TextView
            android:id="@+id/btnFxBack"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:text="@string/back"
            android:textColor="#888888"
            android:textSize="11sp"
            android:fontFamily="monospace"
            android:padding="4dp" />
    </RelativeLayout>

    <!-- Preview -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="18dp"
        android:layout_marginBottom="4dp">

        <com.kaelvalen.glyphmatrixdraw.ui.PixelGridView
            android:id="@+id/fxPreview"
            android:layout_width="match_parent"
            android:layout_height="wrap_content" />
    </FrameLayout>

    <!-- Current selection caption -->
    <TextView
        android:id="@+id/tvFxDescription"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="18dp"
        android:layout_marginTop="4dp"
        android:text="@string/fx_desc_breathing"
        android:textColor="#888888"
        android:textSize="10sp"
        android:fontFamily="monospace"
        android:gravity="start"
        android:minLines="2" />

    <!-- Scrollable effect catalogue + sliders -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:scrollbars="none"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="18dp"
            android:paddingTop="8dp"
            android:paddingBottom="18dp">

            <!-- Category sections are built at runtime, appended to fxCategoryContainer -->
            <LinearLayout
                android:id="@+id/fxCategoryContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical" />

            <!-- Frame count -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="14dp">

                <TextView
                    android:layout_width="60dp"
                    android:layout_height="wrap_content"
                    android:text="@string/fx_frames"
                    android:textColor="#666666"
                    android:textSize="9sp"
                    android:letterSpacing="0.2"
                    android:fontFamily="monospace" />

                <SeekBar
                    android:id="@+id/seekFxFrames"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:max="56"
                    android:progress="18"
                    android:progressTint="#FFFFFF"
                    android:thumbTint="#FFFFFF" />

                <TextView
                    android:id="@+id/tvFxFrames"
                    android:layout_width="40dp"
                    android:layout_height="wrap_content"
                    android:text="@string/default_frames"
                    android:textColor="#888888"
                    android:textSize="10sp"
                    android:fontFamily="monospace"
                    android:gravity="end"
                    android:layout_marginStart="8dp" />
            </LinearLayout>

            <!-- Delay -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="6dp">

                <TextView
                    android:layout_width="60dp"
                    android:layout_height="wrap_content"
                    android:text="@string/delay"
                    android:textColor="#666666"
                    android:textSize="9sp"
                    android:letterSpacing="0.2"
                    android:fontFamily="monospace" />

                <SeekBar
                    android:id="@+id/seekFxDelay"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:max="400"
                    android:progress="80"
                    android:progressTint="#FFFFFF"
                    android:thumbTint="#FFFFFF" />

                <TextView
                    android:id="@+id/tvFxDelay"
                    android:layout_width="56dp"
                    android:layout_height="wrap_content"
                    android:text="@string/default_delay"
                    android:textColor="#888888"
                    android:textSize="10sp"
                    android:fontFamily="monospace"
                    android:gravity="end"
                    android:layout_marginStart="8dp" />
            </LinearLayout>

            <!-- Options -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="10dp">

                <TextView
                    android:id="@+id/btnFxUseCurrent"
                    android:layout_width="0dp"
                    android:layout_height="36dp"
                    android:layout_weight="1"
                    android:text="@string/fx_use_current"
                    android:textColor="#CCCCCC"
                    android:textSize="9sp"
                    android:letterSpacing="0.15"
                    android:fontFamily="monospace"
                    android:gravity="center"
                    android:background="@drawable/chip_bg"
                    android:layout_marginEnd="6dp" />

                <TextView
                    android:id="@+id/btnFxPingPong"
                    android:layout_width="0dp"
                    android:layout_height="36dp"
                    android:layout_weight="1"
                    android:text="@string/ping_pong"
                    android:textColor="#CCCCCC"
                    android:textSize="9sp"
                    android:letterSpacing="0.15"
                    android:fontFamily="monospace"
                    android:gravity="center"
                    android:background="@drawable/chip_bg" />
            </LinearLayout>

            <!-- Actions -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="12dp">

                <TextView
                    android:id="@+id/btnFxPreview"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:text="@string/fx_pause"
                    android:textColor="#FFFFFF"
                    android:textSize="10sp"
                    android:letterSpacing="0.2"
                    android:fontFamily="monospace"
                    android:gravity="center"
                    android:background="@drawable/btn_outline"
                    android:layout_marginEnd="8dp" />

                <TextView
                    android:id="@+id/btnFxSave"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:text="@string/fx_save"
                    android:textColor="#080808"
                    android:textSize="10sp"
                    android:letterSpacing="0.25"
                    android:fontFamily="monospace"
                    android:gravity="center"
                    android:background="@drawable/btn_primary" />
            </LinearLayout>

        </LinearLayout>
    </ScrollView>

</LinearLayout>

<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#080808"
    android:paddingTop="40dp">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingHorizontal="18dp"
        android:paddingBottom="12dp">

        <TextView
            android:id="@+id/tvAnimGalleryTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerVertical="true"
            android:text="@string/animations_title"
            android:textColor="#FFFFFF"
            android:textSize="13sp"
            android:letterSpacing="0.3"
            android:fontFamily="monospace" />

        <TextView
            android:id="@+id/btnAnimGalleryBack"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:text="@string/close"
            android:textColor="#888888"
            android:textSize="18sp"
            android:padding="8dp" />
    </RelativeLayout>

    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#181818" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvAnimations"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:paddingTop="6dp"
        android:clipToPadding="false" />

    <LinearLayout
        android:id="@+id/emptyAnimView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:gravity="center"
        android:visibility="gone"
        android:paddingHorizontal="32dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/empty_animations_title"
            android:textColor="#CCCCCC"
            android:textSize="13sp"
            android:letterSpacing="0.25"
            android:fontFamily="monospace"
            android:layout_marginBottom="8dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/empty_animations_body"
            android:textColor="#666666"
            android:textSize="11sp"
            android:fontFamily="monospace"
            android:gravity="center" />
    </LinearLayout>

    <TextView
        android:id="@+id/fabNewAnimation"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:layout_marginHorizontal="18dp"
        android:layout_marginVertical="12dp"
        android:text="@string/new_animation"
        android:textColor="#080808"
        android:textSize="11sp"
        android:letterSpacing="0.2"
        android:fontFamily="monospace"
        android:gravity="center"
        android:background="@drawable/btn_primary" />
</LinearLayout>
